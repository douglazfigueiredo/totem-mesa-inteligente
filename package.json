{
  "name": "totem-mesa-inteligente",
  "version": "0.1.0",
  "private": true,
  "description": "SaaS de totem-de-mesa para pizzarias, restaurantes, lanchonetes e hamburguerias",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.9.0",
    "dotenv": "^16.4.5",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
