# ──────────────────────────────────────────────────────────────────────────
# Cloud env vars (cópia para apps/cloud/.env.local em dev,
# ou Vercel Project → Settings → Environment Variables em prod)
# ──────────────────────────────────────────────────────────────────────────

# Postgres (Neon — crie em https://neon.tech, copie a connection string aqui)
DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth (Auth.js v5)
# AUTH_SECRET: 32 bytes base64 — gere com `openssl rand -base64 32`
AUTH_SECRET=""
# AUTH_URL: em prod, deve ser a URL pública do projeto Vercel (ex https://app.totemmesa.com).
# Em dev local, http://localhost:3000.
AUTH_URL="http://localhost:3000"
# AUTH_TRUST_HOST=true é requerido em ambientes onde a URL é detectada via headers
# (Vercel já injeta os corretos, mas explícito evita avisos).
AUTH_TRUST_HOST="true"

# E-mail (magic link)
# Dev: Mailtrap (smtp.mailtrap.io). Prod: Resend / Postmark / SES.
EMAIL_SERVER_HOST="smtp.mailtrap.io"
EMAIL_SERVER_PORT=2525
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@totemmesa.dev"

# Seed (db:seed) — owner default vinculado ao tenant 'dev'.
# Em prod, o seed não roda — owners são criados manualmente.
EMAIL_DEV_OWNER="douglasarts@gmail.com"

# Seed (db:seed) — hub dev opt-in pra testar /api/catalog/snapshot
# Gere com: openssl rand -hex 32
DEV_HUB_API_KEY=""
