# ──────────────────────────────────────────────────────────────────────────
# TotemMesa Hub — env do mini-PC da loja
# ──────────────────────────────────────────────────────────────────────────

# Secret para autenticar a UI admin do hub (http://<ip>:4000/admin).
# Gere uma vez por instalação:  openssl rand -hex 32
ADMIN_SECRET=

# Owner da imagem GHCR (default: dono atual do repo)
GH_OWNER=douglazfigueiredo

# Tag da imagem do hub. 'stable' acompanha último build de main.
# Pode pinar em SHA específico em produção: HUB_TAG=abc1234.
HUB_TAG=stable

# Porta exposta no host (interno do container fixo em 4000)
HUB_PORT=4000

# Logs: debug | info | warn | error
LOG_LEVEL=info

# Intervalo do poller cloud→hub (snapshot, config, mesas, funcionários).
# Default 60s. Diminuir só se necessário.
CATALOG_POLL_INTERVAL_MS=60000

# Backup automático do SQLite. Default: 1×/dia, mantém 7 cópias.
# Setar BACKUP_INTERVAL_HOURS=0 desliga o worker.
# Backups vão em /data/backups/ dentro do container.
BACKUP_INTERVAL_HOURS=24
BACKUP_KEEP=7

# CORS: lista CSV de origens permitidas. Vazio = aceita tudo (default
# em dev). Em produção, listar os domínios dos PWAs:
#   ALLOWED_ORIGINS=https://totem.totemmesa.app,https://kds.totemmesa.app,https://waiter.totemmesa.app
ALLOWED_ORIGINS=

# Auto-update via Watchtower. Default desligado.
# Ative só se confiar em deploys automáticos do main.
# Para subir com auto-update:  docker compose --profile auto-update up -d
ENABLE_AUTO_UPDATE=false
